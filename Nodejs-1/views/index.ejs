
<%- include('layouts/header') %>

<div class="container">
  <h1 class="text-center mt-4"><%= title %></h1>
  
  <% if (user) { %>
    <p class="text-right">Bienvenido, <%= user.nombre %></p>
  <% } else { %>
    <p class="text-right">
      <a href="/login" class="btn btn-primary">Iniciar Sesión</a>
      <a href="/register" class="btn btn-secondary">Registrarse</a>
    </p>
  <% } %>

  <div id="restaurantes" class="row mt-4"></div>
</div>

<script>
fetch('/api/restaurantes')
  .then(response => response.json())
  .then(restaurantes => {
    const container = document.getElementById('restaurantes');
    restaurantes.forEach(rest => {
      container.innerHTML += `
        <div class="col-md-4 mb-4">
          <div class="restaurante-card">
            <h2 class="restaurante-nombre">${rest.nombre}</h2>
            <p class="restaurante-info">${rest.descripcion || ''}</p>
            <p>Dirección: ${rest.direccion}</p>
            <button class="btn btn-primary" onclick="verMenu(${rest.id})">Ver Menú</button>
          </div>
        </div>
      `;
    });
  })
  .catch(error => console.error('Error:', error));
</script>

<%- include('layouts/footer') %>
